# TikHub API Keys (https://tikhub.io)
TIKHUB_API_KEY_XHS=your_xhs_api_key_here
TIKHUB_API_KEY_YT=your_youtube_api_key_here
TIKHUB_API_KEY_DOUYIN=your_douyin_api_key_here

# Admin API Key (for admin endpoints like grant-vip)
ADMIN_API_KEY=your_admin_api_key_here

# Admin Emails (comma-separated list of admin users who can call admin APIs)
ADMIN_EMAILS=admin@example.com,another_admin@example.com

# JWT Secret (for authentication)
JWT_SECRET=your_jwt_secret_here

# Email Verification (optional - set to true to require email verification after registration)
EMAIL_VERIFICATION_ENABLED=false

# Resend Email API Key (https://resend.com)
RESEND_API_KEY=your_resend_api_key_here

# Lemon Squeezy API Key (https://lemonsqueezy.com)
LEMON_SQUEEZY_API_KEY=your_lemonsqueezy_api_key_here
LEMON_SQUEEZY_STORE_ID=your_store_id_here
LEMON_SQUEEZY_PRODUCT_ID=your_product_id_here
LEMON_SQUEEZY_WEBHOOK_SECRET=your_webhook_secret_here

# Database (Turso)
DATABASE_URL=libsql://your-database.turso.io
DATABASE_AUTH_TOKEN=your_turso_auth_token_here

# Server
PORT=3000
NODE_ENV=production
