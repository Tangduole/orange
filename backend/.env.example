# ============================================
# 橙子下载器 - 环境变量配置
# ============================================
# 复制这份文件为 .env，填入真实值
# cp .env.example .env

# 端口（一般不改）
PORT=3000
NODE_ENV=production
# 本地开发可设为 development；生产必须配置 Turso/JWT 等关键变量
# NODE_ENV=development

# -------- 日志配置 --------
LOG_LEVEL=info
# 文件保留时间（小时）：未分层配置时使用 FILE_RETENTION_HOURS
FILE_RETENTION_HOURS=24
GUEST_FILE_RETENTION_HOURS=24
FREE_FILE_RETENTION_HOURS=24
PRO_FILE_RETENTION_HOURS=168
# 服务器代下单文件最大字节数（默认 500MB）
MAX_STREAM_DOWNLOAD_BYTES=524288000

# -------- TikHub API Keys --------
# 从 https://www.tikhub.io/ 获取
TIKHUB_API_KEY_YT=your_youtube_api_key_here
TIKHUB_API_KEY_XHS=your_xiaohongshu_api_key_here
TIKHUB_API_KEY_DOUYIN=your_douyin_api_key_here
TIKHUB_API_KEY_INSTAGRAM=your_instagram_api_key_here
TIKHUB_API_KEY_WECHAT=your_wechat_api_key_here

# -------- Yout.com API (YouTube 下载) --------
# https://yout.com/api/ - 按次计费，$10/1000次
YOUT_API_KEY=your_yout_api_key_here
YOUT_REQUEST_TIMEOUT_MS=120000

# -------- 数据库 (Turso) --------
# 从 https://cloud.turso.io 获取
TURSO_DATABASE_URL=libsql://your-database-name-your-org.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here
# 未设置 TURSO_DATABASE_URL 时使用本地 SQLite
# 强烈建议把数据库放到代码目录之外，避免误打包/泄露（绝对路径或相对路径都可，可省略 file: 前缀）
# 例：LOCAL_DB_PATH=/var/lib/orange/users.db
LOCAL_DB_PATH=./data/users.db

# -------- 认证 --------
JWT_SECRET=your_random_jwt_secret_here
# 可选：下载签名专用密钥；未设置时回退 JWT_SECRET
DOWNLOAD_URL_SECRET=your_random_download_url_secret_here

# -------- 邮件 (Resend) --------
# 从 https://resend.com 获取
RESEND_API_KEY=re_your_resend_api_key_here

# -------- Cloudflare --------
CLOUDFLARE_EMAIL=your@email.com
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_KEY=your_cloudflare_api_key
CLOUDFLARE_AI_TOKEN=your_cloudflare_ai_token

# -------- AI 文案/摘要（OpenAI 兼容接口） --------
AI_API_URL=https://api.deepseek.com/v1
AI_API_KEY=your_ai_api_key_here
AI_MODEL=deepseek-chat
# AI 文案月额度；-1 表示不限，当前文案提取接口仍要求 Pro
AI_COPYWRITE_MONTHLY_LIMIT_FREE=0
AI_COPYWRITE_MONTHLY_LIMIT_PRO=200
# 仅供自动化 smoke 使用；正式会员流程请保持 0 并配置真实 AI_API_KEY
DEV_COPYWRITE_MOCK=0

# -------- 支付渠道 --------
# 选择当前生效的支付 provider：lemonsqueezy（默认）| creem
PAYMENT_PROVIDER=lemonsqueezy

# -------- 支付 (Lemon Squeezy) --------
LEMON_SQUEEZY_API_KEY=your_lemonsqueezy_api_key_here
LEMON_SQUEEZY_STORE_ID=your_store_id_here
LEMON_SQUEEZY_PRODUCT_ID=your_product_id_here
LEMON_SQUEEZY_WEBHOOK_SECRET=your_webhook_secret_here

# -------- 支付 (Creem) --------
# https://creem.io —— Merchant of Record，全球收款 + 自动税务
# 切换：在上面把 PAYMENT_PROVIDER 改成 creem，然后填下面这些
# 详见 docs/CREEM_MIGRATION.md
CREEM_API_KEY=
CREEM_WEBHOOK_SECRET=
CREEM_API_BASE=https://api.creem.io
CREEM_PRODUCT_ID_BASIC_MONTHLY=
CREEM_PRODUCT_ID_BASIC_YEARLY=
CREEM_PRODUCT_ID_PRO_MONTHLY=
CREEM_PRODUCT_ID_PRO_YEARLY=

# -------- App URL --------
APP_URL=https://www.orangedl.com

# -------- Cobalt（高画质 X / 多平台兜底） --------
# 自托管 cobalt 实例：https://github.com/imputnet/cobalt
# 部署文档：docs/COBALT_SETUP.md
# 留空 = 不启用，X 下载会自动回落到 fxtwitter（540p~720p）
COBALT_API_URL=
# 如果你的 cobalt 实例开了 API_AUTH_REQUIRED=1，把对应 key 填这里
COBALT_API_KEY=
# 单次解析超时（ms），默认 15000
COBALT_REQUEST_TIMEOUT_MS=15000
# 单文件下载超时（ms），默认 180000（3 分钟）
COBALT_DOWNLOAD_TIMEOUT_MS=180000
COBALT_MAX_REDIRECTS=5

# -------- yt-dlp --------
# 默认校验证书；仅在确有运营需要时设为 1
YTDLP_NO_CHECK_CERTIFICATES=0

# -------- ASR 模式 --------
ASR_MODE=cloudflare
# ASR 纠错业务词，可追加品牌名、产品词、行业词，逗号分隔
ASR_CORRECTION_TERMS=仿真,磁吸,材质,工艺,配件,模型

# -------- Telegram Bot --------
TELEGRAM_BOT_TOKEN=
# Telegram setWebhook secret_token，用于验证 /api/bot/telegram 请求来源
TELEGRAM_WEBHOOK_SECRET=your_random_telegram_webhook_secret_here
