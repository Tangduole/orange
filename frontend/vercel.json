{
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://api.orangedl.com/api/:path*" },
    { "source": "/download/:path*", "destination": "https://api.orangedl.com/download/:path*" },
    { "source": "/health", "destination": "https://api.orangedl.com/health" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
